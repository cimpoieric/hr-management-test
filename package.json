{
  "name": "hr-management",
  "version": "1.0.0",
  "description": "HR Management - Sistem local pentru gestiunea angajatilor, documentelor si detasarilor",
  "author": "HR Management",
  "private": true,
  "main": "electron/main.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.js",
    "final-cleanup": "node scripts/final-cleanup.js",
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:script": "node scripts/start.js",
    "start:dev": "node scripts/start.js --dev",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "import:w18": "tsx scripts/import-w18-detachering.ts",
    "backfill:deployments": "tsx scripts/backfill-detached-deployments.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:e2e": "playwright test",
    "stripe:create-catalog": "tsx scripts/stripe-create-catalog.ts",
    "wipe:storage": "tsx scripts/wipe-storage.ts",
    "subset-pdf-fonts": "node scripts/subset-pdf-fonts.mjs",
    "restructure-api": "node scripts/restructure-api.mjs",
    "electron": "electron .",
    "electron:build": "electron-builder",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1",
    "electron:desktop-shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/update-desktop-shortcut.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1047.0",
    "@aws-sdk/s3-request-presigner": "^3.1047.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@stripe/stripe-js": "^9.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "adm-zip": "^0.5.17",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "i18next": "^26.1.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "imapflow": "^1.3.3",
    "jose": "^6.0.0",
    "js-cookie": "^3.0.5",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.460.0",
    "next": "^15.0.0",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.75.0",
    "react-i18next": "^17.0.7",
    "resend": "^4.8.0",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "winston": "^3.17.0",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@prisma/client": "6.19.3",
    "@types/adm-zip": "^0.5.8",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.4.0",
    "prisma": "6.19.3",
    "server-only": "^0.0.1",
    "subset-font": "^2.5.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.hrmanagement.app",
    "productName": "HR Management",
    "icon": "build/icon.ico",
    "disableSanityCheckAsar": true,
    "asar": true,
    "electronFuses": {
      "enableEmbeddedAsarIntegrityValidation": false
    },
    "beforeBuild": "scripts/electron-before-build.js",
    "files": [
      "package.json",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "hr-next",
        "filter": [
          "package.json",
          "package-lock.json",
          "next.config.ts",
          "tsconfig.json",
          "next-env.d.ts",
          "tailwind.config.ts",
          "postcss.config.mjs",
          "scripts/**/*",
          "public/**/*",
          "prisma/**/*",
          "src/**/*",
          ".next/**/*",
          "node_modules/**/*",
          "data/**/*",
          ".env.example"
        ]
      }
    ],
    "afterPack": "scripts/after-pack-env.js",
    "directories": {
      "output": "release-electron",
      "buildResources": "build"
    },
    "win": {
      "signAndEditExecutable": false,
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName} Setup ${version}.${ext}",
      "shortcutName": "HR Management"
    }
  },
  "keywords": [
    "hr",
    "management",
    "employees",
    "documents",
    "romania",
    "local"
  ],
  "license": "UNLICENSED",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
