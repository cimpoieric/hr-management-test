# Copiază în Vercel Dashboard: Settings → Environment Variables
# Nu publica acest fișier în repo cu valori reale
#
# Generează secrete noi pentru producție (NU refolosi .env local):
#   ENCRYPTION_KEY: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   JWT_SECRET:     node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#
# ⚠️  ENCRYPTION_KEY pierdută = date criptate (CNP, IBAN) IRECUPERABILE.
# ⚠️  Pe Vercel filesystem-ul e read-only — obligatoriu PostgreSQL + R2/S3.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Pooled URL (Neon pooler / Vercel Postgres) — folosit la runtime
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Conexiune directă pentru `prisma migrate deploy` (fără pooler)
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# Dacă providerul expune doar DATABASE_URL_UNPOOLED, setează aceeași valoare aici.

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET="minim-32-caractere-aleatorii"
JWT_EXPIRES_IN="8h"

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
ENCRYPTION_KEY="64-caractere-hex"

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://domeniul-tau.vercel.app"
# VERCEL_URL este setat automat de Vercel (fallback în appUrl.ts)

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 / S3) — documente, importuri, logo, backup, rapoarte PDF
# -----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_REGION="auto"
# Domeniu public R2 (custom domain sau r2.dev) — logo/backup direct în browser
S3_PUBLIC_BASE_URL="https://pub-<hash>.r2.dev"

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_STRIPE_PRICE_STARTER="price_..."
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE="price_..."
NEXT_PUBLIC_STRIPE_PRICE_CUSTOM=""
STRIPE_CHECKOUT_ENABLED="true"
STRIPE_TRIAL_PERIOD_DAYS="14"
STRIPE_GRACE_PERIOD_DAYS="7"

# -----------------------------------------------------------------------------
# Email (reset parolă, fluturași) — preferă Resend pe Vercel
# -----------------------------------------------------------------------------
# Resend (recomandat serverless): https://resend.com — domeniu verificat în FROM_EMAIL
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@domeniul-tau.ro"
FROM_NAME="HR Management"

# SMTP (fallback; multe hosturi blochează IP Vercel)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Opțional: POST /api/internal/test-email cu Authorization: Bearer <secret>
EMAIL_TEST_SECRET=""

# Opțional: POST /api/internal/wipe-storage (header x-confirm: wipe-all-storage)
STORAGE_WIPE_SECRET=""

# -----------------------------------------------------------------------------
# Contact / pricing UI
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SALES_EMAIL="vanzari@firma.ro"
NEXT_PUBLIC_CONTACT_EMAIL="contact@firma.ro"
NEXT_PUBLIC_PRICING_TRIAL_DAYS="14"

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
DEBUG="false"

# -----------------------------------------------------------------------------
# IMAP (opțional — import email; pe Vercel folosește Cron + configurare în app)
# -----------------------------------------------------------------------------
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_TLS="true"

# -----------------------------------------------------------------------------
# Opțional
# -----------------------------------------------------------------------------
# Parolă arhivă backup legacy (Electron / scripts/start.js)
# BACKUP_PASSWORD=""
