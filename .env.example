# =============================================================================
# HR Management — environment template
# Copy to `.env` (or `.env.local` for Next.js) and fill values. Never commit real secrets.
# `npm run setup` can generate ENCRYPTION_KEY and JWT_SECRET when missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
# PostgreSQL (recommended for production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# SQLite (local dev — path is relative to the `prisma/` folder):
# DATABASE_URL="file:../data/app.db"
DATABASE_URL=""

# Direct (non-pooled) URL for migrations / Prisma CLI — optional, e.g. Neon/Vercel Postgres
DATABASE_URL_UNPOOLED=""

# -----------------------------------------------------------------------------
# Auth / JWT
# -----------------------------------------------------------------------------
# Used by the app for sessions (HTTP-only cookie signing). Min ~32 chars.
JWT_SECRET=""
# Token lifetime, e.g. 8h, 24h, 7d
JWT_EXPIRES_IN="8h"

# Next.js / tooling compatibility (this project primarily uses JWT_SECRET above)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Encryption (sensitive fields in DB — 64 hex chars; do not rotate without a migration plan)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# Stripe (pricing page + checkout + webhooks)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs from Stripe Dashboard (exposed to the browser — must be NEXT_PUBLIC_)
NEXT_PUBLIC_STRIPE_PRICE_STARTER=""
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=""
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=""
NEXT_PUBLIC_STRIPE_PRICE_CUSTOM=""

# Trial length (days). 0 = no trial in Stripe checkout.
NEXT_PUBLIC_PRICING_TRIAL_DAYS="14"
STRIPE_TRIAL_PERIOD_DAYS="14"

# Days of limited access after a failed invoice payment (subscription grace)
STRIPE_GRACE_PERIOD_DAYS="7"

# Enterprise / Custom: mailto when no price ID is configured
NEXT_PUBLIC_SALES_EMAIL=""
NEXT_PUBLIC_CONTACT_EMAIL=""

# -----------------------------------------------------------------------------
# Email — Resend (optional; primary app flow uses SMTP via Settings UI / DB)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@example.com"
FROM_NAME="HR Manager"

# Email — SMTP (optional legacy / env documentation; prefer in-app Email settings)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# -----------------------------------------------------------------------------
# Email import — IMAP (optional fallback when not configured in the app)
# -----------------------------------------------------------------------------
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_TLS="true"

# -----------------------------------------------------------------------------
# App URLs (links in emails, Stripe redirects, canonical origin)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# HTTP server (custom Node / `scripts/start.js` / Electron packaging)
# -----------------------------------------------------------------------------
PORT="3000"
HOST="0.0.0.0"

# -----------------------------------------------------------------------------
# Local file storage
# -----------------------------------------------------------------------------
# Directory for uploaded documents (default: ./data/documents)
DOCUMENTS_PATH=""

# -----------------------------------------------------------------------------
# Automated backup (optional — see scripts/start.js and backup API)
# -----------------------------------------------------------------------------
BACKUP_AUTO="false"
BACKUP_INTERVAL_MS=""
BACKUP_PASSWORD=""

# -----------------------------------------------------------------------------
# Database seed (first admin user — `npm run db:seed`)
# -----------------------------------------------------------------------------
SEED_ADMIN_PASSWORD=""

# -----------------------------------------------------------------------------
# One-off scripts (optional)
# -----------------------------------------------------------------------------
FIX_USER_EMAIL=""
FIX_NEW_PASSWORD=""

# -----------------------------------------------------------------------------
# Production / Vercel (optional — see .env.production.example)
# -----------------------------------------------------------------------------
# Vercel Blob or similar when not using local filesystem
BLOB_READ_WRITE_TOKEN=""

# S3-compatible storage (optional alternative to Blob)
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET=""
# S3_REGION=""
# S3_ENDPOINT=""

# Debug logging (use "false" in production)
DEBUG="false"
