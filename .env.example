# =============================================================================
# HR Management — environment template
# Copy to `.env` or `.env.local`. Never commit real secrets.
# Production (Vercel): see `.env.production.example`
# `npm run setup` can generate ENCRYPTION_KEY and JWT_SECRET when missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# PostgreSQL (production / staging):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# SQLite (local dev — path relative to `prisma/`):
# DATABASE_URL="file:../data/app.db"
DATABASE_URL=""

# Prisma `directUrl` (migrations) — same as Neon/Vercel «unpooled» URL
DIRECT_DATABASE_URL=""
# Alias acceptat de unii provideri; dacă e setat, copiază valoarea în DIRECT_DATABASE_URL
DATABASE_URL_UNPOOLED=""

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
JWT_SECRET=""
JWT_EXPIRES_IN="8h"

# Next.js tooling (fallback URL dacă NEXT_PUBLIC_APP_URL lipsește)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# -----------------------------------------------------------------------------
# Encryption (64 hex chars — do not rotate without a migration plan)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=""

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Storage (Cloudflare R2 / S3) — required on Vercel
# Local dev: optional; without S3, documents use ./data/documents
# -----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_PUBLIC_BASE_URL="https://pub-<hash>.r2.dev"

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_STRIPE_PRICE_STARTER=""
NEXT_PUBLIC_STRIPE_PRICE_BUSINESS=""
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE=""
NEXT_PUBLIC_STRIPE_PRICE_CUSTOM=""
STRIPE_CHECKOUT_ENABLED="true"
STRIPE_TRIAL_PERIOD_DAYS="14"
STRIPE_GRACE_PERIOD_DAYS="7"

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL=""
FROM_NAME="HR Management"

# -----------------------------------------------------------------------------
# Contact / pricing UI
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SALES_EMAIL=""
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_PRICING_TRIAL_DAYS="14"

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------
DEBUG="false"

# -----------------------------------------------------------------------------
# IMAP (optional — email import; code uses IMAP_PASSWORD)
# -----------------------------------------------------------------------------
IMAP_HOST=""
IMAP_PORT="993"
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_TLS="true"

# -----------------------------------------------------------------------------
# Local dev / Electron / scripts (not required on Vercel)
# -----------------------------------------------------------------------------
# Set by electron/main.js in desktop builds — enables SQLite import/export API
ELECTRON_MODE=""
ELECTRON_RUN=""
PORT="3000"
HOST="0.0.0.0"
DOCUMENTS_PATH=""
BACKUP_AUTO="false"
BACKUP_INTERVAL_MS=""
BACKUP_PASSWORD=""
SEED_ADMIN_PASSWORD=""
FIX_USER_EMAIL=""
FIX_NEW_PASSWORD=""
IMPORT_ADMIN_PASSWORD=""

# Optional: Resend (deprecated — app uses SMTP)
# RESEND_API_KEY=""
