# HR Management — copiază în .env și completează valorile.
# npm run setup poate genera ENCRYPTION_KEY și JWT_SECRET dacă sunt goale/placeholder.

# ─── Bază de date (Prisma) ───────────────────────────────────────────────────
DATABASE_URL=""

# ─── Secrete aplicație ────────────────────────────────────────────────────────
# Parolă minimă 8 caractere pentru utilizatorul admin la: npm run db:seed
SEED_ADMIN_PASSWORD=""
ENCRYPTION_KEY=""
JWT_SECRET=""
JWT_EXPIRES_IN=""
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── URL public (linkuri în email / redirect) ───────────────────────────────
NEXT_PUBLIC_APP_URL=""

# ─── SMTP (trimitere email / fluturași — completare opțională dacă nu folosești UI) ─
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
FROM_EMAIL=""
FROM_NAME="HR Manager"

# ─── IMAP (import email — fallback când nu e configurat în aplicație) ─────────
IMAP_HOST=""
IMAP_PORT=""
IMAP_USER=""
IMAP_PASSWORD=""
IMAP_TLS=""

# ─── Server local ─────────────────────────────────────────────────────────────
PORT=""
HOST=""

# ─── Căi fișiere ─────────────────────────────────────────────────────────────
DOCUMENTS_PATH=""

# ─── Backup ────────────────────────────────────────────────────────────────────
BACKUP_AUTO=""
BACKUP_INTERVAL_MS=""
BACKUP_PASSWORD=""

# ─── Diverse ───────────────────────────────────────────────────────────────────
DEBUG=""
