# ══════════════════════════════════════════════════════════════════════════════
# HR Management — Variabile de mediu
#
# Copiază acest fișier în .env și ajustează valorile.
# Sau rulează: npm run setup (generează automat cheile secrete)
#
# ATENȚIE: Nu comite acest fișier în git!
# ATENȚIE: Dacă pierzi ENCRYPTION_KEY, datele criptate sunt irecuperabile!
# ══════════════════════════════════════════════════════════════════════════════

# ─── Chei secrete (OBLIGATORIU) ──────────────────────────────────────────────
# ENCRYPTION_KEY: 64 caractere hex (32 bytes) pentru AES-256-GCM
# JWT_SECRET: minim 32 caractere pentru semnarea token-urilor
ENCRYPTION_KEY="CHANGE_ME"
JWT_SECRET="CHANGE_ME"

# ─── Server (opțional) ──────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── Backup automat (opțional) ──────────────────────────────────────────────
BACKUP_AUTO=false
BACKUP_INTERVAL_MS=86400000
BACKUP_PASSWORD=""

# ─── Debug (opțional) ───────────────────────────────────────────────────────
DEBUG=false
